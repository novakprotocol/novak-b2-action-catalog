{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "catalog/schemas/action-contract.v1.schema.json",
  "title": "NOVAK Action Catalog Action Contract v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "action_number",
    "action_id",
    "title",
    "description",
    "domain",
    "subdomain",
    "category",
    "platform",
    "persona",
    "support_level",
    "authority_required",
    "safety_class",
    "mutation_allowed",
    "approval_required",
    "secret_policy",
    "target_policy",
    "network_scan_allowed",
    "runtime_context",
    "script_path",
    "script_sha256",
    "hash_policy",
    "inputs",
    "outputs",
    "evidence_contract",
    "sanitization_policy",
    "adapter_hints",
    "status",
    "accepted_for_baseline",
    "accepted_for_mutation",
    "created_utc",
    "updated_utc"
  ],
  "properties": {
    "schema_version": { "const": "action-contract.v1" },
    "action_number": { "type": "integer", "minimum": 1 },
    "action_id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "domain": { "type": "string" },
    "subdomain": { "type": "string" },
    "category": { "type": "string" },
    "platform": { "type": "string" },
    "persona": { "type": "string" },
    "support_level": { "type": "string" },
    "authority_required": { "type": "string" },
    "safety_class": { "enum": ["evidence_only", "guidance_only", "approved_mutation_gate"] },
    "mutation_allowed": { "type": "boolean" },
    "approval_required": { "type": "boolean" },
    "secret_policy": { "enum": ["no_secrets", "secrets_required_external_reference_only"] },
    "target_policy": { "enum": ["no_targets", "sanitized_targets", "approved_inventory_only"] },
    "network_scan_allowed": { "type": "boolean" },
    "runtime_context": { "type": "string" },
    "script_path": { "type": "string", "pattern": "^action-layers/.+\\.ps1$" },
    "script_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "hash_policy": { "const": "lf-normalized-sha256" },
    "inputs": { "type": "array" },
    "outputs": { "type": "array" },
    "evidence_contract": { "type": "object" },
    "sanitization_policy": { "type": "string" },
    "adapter_hints": { "type": "object" },
    "status": { "type": "string" },
    "accepted_for_baseline": { "type": "boolean" },
    "accepted_for_mutation": { "type": "boolean" },
    "created_utc": { "type": "string" },
    "updated_utc": { "type": "string" }
  }
}
